<div class="modal fade" id="createItemModal" tabindex="-1">
	<div class="modal-dialog">
		<div class="modal-content">

			<div class="modal-header">
				<h5 class="modal-title">Create Item</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>

			<div class="modal-body">
				<form id="createItemForm" enctype="multipart/form-data">
					@Html.AntiForgeryToken()

					<div class="input-group mb-2">
						<input type="file" accept=".jpg,.jpeg,.png,.gif,.webp" name="ImageFile" class="form-control" required />
					</div>

					<div class="input-group mb-2">
						<label for="name" class="input-group-text">Name</label>
						<input type="text" name="Name" id="name" class="form-control" required/>
					</div>
					<span class="text-danger" data-valmsg-for="Name"></span>

					<div class="input-group mb-2">
						<label for="category" class="input-group-text">Category</label>
						<select name="Category" id="category" class="form-select" required>
							<option value="">Select</option>
							<option value="Table">Table</option>
							<option value="Chair">Chair</option>
							<option value="Clothing">Clothing</option>
							<!-- Add more categories as needed -->
						</select>
					</div>
					<span class="text-danger" data-valmsg-for="Category"></span>

					<div class="input-group mb-2">
						<label for="description" class="input-group-text">Description</label>
						<textarea name="Description" id="description" class="form-control" required></textarea>
					</div>

					<div class="input-group mb-2">
						<label for="price" class="input-group-text">Price</label>
						<input type="number" name="Price" id="price" step="0.01" class="form-control" required />
					</div>
					<span class="text-danger" data-valmsg-for="Price"></span>

					<button type="submit" class="btn btn-primary">Save</button>
				</form>
			</div>

		</div>
	</div>
</div>

<div class="modal fade" id="editItemModal">
	<div class="modal-dialog">
		<div class="modal-content">

			<div class="modal-header">
				<h5>Edit Item</h5>
				<button class="btn-close" data-bs-dismiss="modal"></button>
			</div>

			<div class="modal-body">
				<form id="editItemForm" class="justify-content-center" enctype="multipart/form-data">
					@Html.AntiForgeryToken()

					<input type="hidden" id="editId" name="Id" />

					<div class="mb-3">
						<label>Current Image</label><br />
						<img id="currentImage" width="120" class="rounded shadow-sm" />
					</div>

					<!-- Hidden field to keep old image -->
					<input type="hidden" id="existingImage" name="ExistingImage" />

					<!-- File input (leave empty always) -->
					<small class="text-muted">Leave empty to keep current image</small>
					<input id="imageInput" type="file" accept=".jpg,.jpeg,.png,.gif,.webp" name="ImageFile" class="form-control mb-2" />

					<input id="editName" name="Name" class="form-control mb-2" />
					<select id="editCategory" name="Category" class="form-select mb-2">
						<option>Table</option>
						<option>Chair</option>
						<option>Clothing</option>
					</select>
					<textarea id="editDescription" name="Description" class="form-control mb-2"></textarea>
					<input id="editPrice" name="Price" type="number" step="0.01" class="form-control mb-2" />

					<button type="submit" class="btn btn-primary">Update</button>
				</form>
			</div>

		</div>
	</div>
</div>
