@model IEnumerable<Item>
@{
	ViewData["Title"] = "Items";
}

<div class="d-flex justify-content-between align-items-center mb-3">
	<h2>Items</h2>
	<button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createItemModal">
		Create New Item
	</button>
</div>
<hr />

<table class="table" id="itemsTable">
	<thead>
		<tr>
			<th>Image</th>
			<th>Category</th>
			<th>Name</th>
			<th>Description</th>
			<th>Price</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody id="itemsTableBody">
		@foreach(var item in Model)
		{
			<tr data-id="@item.Id" class="align-items-center">
				<td>
					@if (!string.IsNullOrEmpty(item.ImagePath))
					{
						<img src="@item.ImagePath" width="40" height="25"/>
					}
				</td>
				<td>@item.Category</td>
				<td>@item.Name</td>
				<td>@item.Description</td>
				<td>@item.Price.ToString("C")</td>
				<td>
					<button type="button" class="btn btn-sm btn-primary edit-btn"
						data-id="@item.Id"
						data-category="@item.Category"
						data-name="@item.Name"
						data-description="@item.Description"
						data-price="@item.Price">
						Edit
					</button>

					<button type="button" class="btn btn-sm btn-danger delete-btn" data-id="@item.Id">Delete</button>
				</td>
			</tr>
		}
	</tbody>
</table>

<partial name="_itemModalForm" />

<script src="~/js/items.js"></script>