@model List<Item>

<!-- SERVICES GRID -->
<div id="service-container" class="container">

    <!-- FILTERS -->
    <div class="text-center mb-5 p-0">

        <h2 class="mb-5">Browse Services</h2>

        <div class="filter-buttons text-center mb-5">
            <button class="btn filter-btn active" data-category="">All</button>
            <button class="btn filter-btn" data-category="Chair">Decoration</button>
            <button class="btn filter-btn" data-category="Table">Equipment</button>
            <button class="btn filter-btn" data-category="Management">Management</button>
        </div>

    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card service-card h-100">
                    <img src="@item.ImagePath" class="card-img-top service-img p-3" />

                    <div class="card-body d-flex flex-column">
                        <h5>@item.Name</h5>
                        <p class="text-muted">@item.Description</p>

                        <div class="mt-auto">
                            <h6 class="mb-3">$@item.Price</h6>

                            <button class="btn btn-primary-custom w-100 add-to-cart"
                                    data-id="@item.Id">
                                <i class="fa-solid fa-cart-plus me-2"></i>
                                Add to Cart
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        }

    </div>
</div>
